{
	"info": {
		"_postman_id": "inventory-mgmt-connect-rpc",
		"name": "Inventory Management - Connect RPC",
		"description": "Go + Connect RPC microservices for inventory management.\n\nServices:\n- User Service (:8080)\n- Product Service (:8081)\n- Order Service (:8082)\n- Payment Service (:8083)\n\nConnect RPC uses JSON over HTTP POST. All endpoints follow the pattern:\n`POST http://<host>:<port>/<package>.<Service>/<Method>`\n\n## Authentication\n\nMost endpoints require a JWT token. Use the `Login` request first to obtain a token.\nThe token is automatically saved to the `token` collection variable.\nAll protected requests use `Authorization: Bearer {{token}}`.\n\nPublic endpoints (no token required):\n- `UserService/CreateUser`\n- `UserService/Login`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "user_id",
			"value": ""
		},
		{
			"key": "product_id",
			"value": ""
		},
		{
			"key": "order_id",
			"value": ""
		},
		{
			"key": "payment_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "User Service",
			"description": "User registration, authentication, and profile management.\nPort: 8080",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.accessToken) {",
									"    pm.collectionVariables.set('token', res.accessToken);",
									"    console.log('Saved token:', res.accessToken.substring(0, 30) + '...');",
									"}",
									"if (res.user && res.user.id) {",
									"    pm.collectionVariables.set('user_id', res.user.id);",
									"    console.log('Saved user_id:', res.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"tanaka@example.com\",\n  \"password\": \"pass1234\"\n}"
						},
						"url": {
							"raw": "{{user_service_url}}/user.v1.UserService/Login",
							"host": ["{{user_service_url}}"],
							"path": ["user.v1.UserService", "Login"]
						},
						"description": "Authenticate with email and password.\n\nReturns a JWT access token that is automatically saved to the `token` collection variable.\nThe token must be included as `Authorization: Bearer {{token}}` in all subsequent protected requests.\n\n**Public endpoint — no Authorization header required.**"
					}
				},
				{
					"name": "CreateUser",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.user && res.user.id) {",
									"    pm.collectionVariables.set('user_id', res.user.id);",
									"    console.log('Saved user_id:', res.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"tanaka@example.com\",\n  \"name\": \"Tanaka Taro\",\n  \"password\": \"pass1234\",\n  \"role\": \"ROLE_CUSTOMER\"\n}"
						},
						"url": {
							"raw": "{{user_service_url}}/user.v1.UserService/CreateUser",
							"host": ["{{user_service_url}}"],
							"path": ["user.v1.UserService", "CreateUser"]
						},
						"description": "Register a new user.\n\nRoles: `ROLE_CUSTOMER`, `ROLE_ADMIN`\n\nThe user_id is automatically saved to collection variables for subsequent requests.\n\n**Public endpoint — no Authorization header required.**"
					}
				},
				{
					"name": "GetUser",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{user_id}}\"\n}"
						},
						"url": {
							"raw": "{{user_service_url}}/user.v1.UserService/GetUser",
							"host": ["{{user_service_url}}"],
							"path": ["user.v1.UserService", "GetUser"]
						},
						"description": "Fetch a user by ID. Returns NOT_FOUND if the user does not exist or is soft-deleted."
					}
				},
				{
					"name": "ListUsers",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"pageSize\": 20,\n  \"page\": 1\n}"
						},
						"url": {
							"raw": "{{user_service_url}}/user.v1.UserService/ListUsers",
							"host": ["{{user_service_url}}"],
							"path": ["user.v1.UserService", "ListUsers"]
						},
						"description": "List active users with pagination."
					}
				},
				{
					"name": "UpdateUser",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{user_id}}\",\n  \"name\": \"Tanaka Jiro\",\n  \"email\": \"jiro@example.com\"\n}"
						},
						"url": {
							"raw": "{{user_service_url}}/user.v1.UserService/UpdateUser",
							"host": ["{{user_service_url}}"],
							"path": ["user.v1.UserService", "UpdateUser"]
						},
						"description": "Update user name and email."
					}
				},
				{
					"name": "DeleteUser",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{user_id}}\"\n}"
						},
						"url": {
							"raw": "{{user_service_url}}/user.v1.UserService/DeleteUser",
							"host": ["{{user_service_url}}"],
							"path": ["user.v1.UserService", "DeleteUser"]
						},
						"description": "Soft-delete a user. The user will no longer appear in ListUsers or GetUser."
					}
				},
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{user_service_url}}/healthz",
							"host": ["{{user_service_url}}"],
							"path": ["healthz"]
						},
						"description": "Health check endpoint."
					}
				}
			]
		},
		{
			"name": "Product Service",
			"description": "Product catalog and inventory management.\nPort: 8081",
			"item": [
				{
					"name": "CreateProduct",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.product && res.product.id) {",
									"    pm.collectionVariables.set('product_id', res.product.id);",
									"    console.log('Saved product_id:', res.product.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sku\": \"LAPTOP-001\",\n  \"name\": \"MacBook Pro\",\n  \"description\": \"Apple laptop 14 inch\",\n  \"priceCents\": 199900,\n  \"stockQuantity\": 10,\n  \"category\": \"electronics\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/CreateProduct",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "CreateProduct"]
						},
						"description": "Register a new product.\n\n- `priceCents`: Price in cents (199900 = $1,999.00)\n- `sku`: Must be unique\n\nThe product_id is automatically saved to collection variables."
					}
				},
				{
					"name": "CreateProduct (2nd item)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.product && res.product.id) {",
									"    pm.collectionVariables.set('product_id_2', res.product.id);",
									"    console.log('Saved product_id_2:', res.product.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sku\": \"MOUSE-001\",\n  \"name\": \"Magic Mouse\",\n  \"description\": \"Apple wireless mouse\",\n  \"priceCents\": 9900,\n  \"stockQuantity\": 50,\n  \"category\": \"electronics\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/CreateProduct",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "CreateProduct"]
						},
						"description": "Register a second product for testing multi-item orders."
					}
				},
				{
					"name": "GetProduct",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{product_id}}\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/GetProduct",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "GetProduct"]
						},
						"description": "Fetch a product by ID."
					}
				},
				{
					"name": "ListProducts",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"pageSize\": 20,\n  \"page\": 1\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/ListProducts",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "ListProducts"]
						},
						"description": "List products with pagination. Optionally filter by `category`."
					}
				},
				{
					"name": "ListProducts (by category)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"pageSize\": 20,\n  \"page\": 1,\n  \"category\": \"electronics\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/ListProducts",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "ListProducts"]
						},
						"description": "List products filtered by category."
					}
				},
				{
					"name": "UpdateProduct",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{product_id}}\",\n  \"name\": \"MacBook Pro M4\",\n  \"description\": \"Apple laptop 14 inch with M4 chip\",\n  \"priceCents\": 219900,\n  \"category\": \"electronics\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/UpdateProduct",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "UpdateProduct"]
						},
						"description": "Update product metadata. Does NOT change stock (use UpdateStock instead)."
					}
				},
				{
					"name": "UpdateStock (restock +5)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"{{product_id}}\",\n  \"delta\": 5,\n  \"reason\": \"STOCK_CHANGE_REASON_RESTOCK\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/UpdateStock",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "UpdateStock"]
						},
						"description": "Add stock.\n\n- `delta`: positive = add, negative = remove\n- `reason`: RESTOCK, SALE, ADJUSTMENT, RETURN\n- Uses SELECT ... FOR UPDATE for concurrency safety"
					}
				},
				{
					"name": "UpdateStock (adjustment -3)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"{{product_id}}\",\n  \"delta\": -3,\n  \"reason\": \"STOCK_CHANGE_REASON_ADJUSTMENT\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/UpdateStock",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "UpdateStock"]
						},
						"description": "Remove stock manually. Returns FAILED_PRECONDITION if stock would go below 0."
					}
				},
				{
					"name": "GetStockLevel",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"{{product_id}}\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/GetStockLevel",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "GetStockLevel"]
						},
						"description": "Get current stock quantity and recent movement audit trail (up to 10 entries)."
					}
				},
				{
					"name": "DeleteProduct",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{product_id}}\"\n}"
						},
						"url": {
							"raw": "{{product_service_url}}/product.v1.ProductService/DeleteProduct",
							"host": ["{{product_service_url}}"],
							"path": ["product.v1.ProductService", "DeleteProduct"]
						},
						"description": "Soft-delete a product."
					}
				}
			]
		},
		{
			"name": "Order Service",
			"description": "Order management.\nPort: 8082\n\nCross-service calls:\n- user-service (verify user)\n- product-service (check/deduct stock)",
			"item": [
				{
					"name": "CreateOrder (single item)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.order && res.order.id) {",
									"    pm.collectionVariables.set('order_id', res.order.id);",
									"    console.log('Saved order_id:', res.order.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/order.v1.OrderService/CreateOrder",
							"host": ["{{order_service_url}}"],
							"path": ["order.v1.OrderService", "CreateOrder"]
						},
						"description": "Place a new order.\n\nThis triggers cross-service calls:\n1. order-service -> user-service: GetUser (verify exists)\n2. order-service -> product-service: GetProduct (check stock)\n3. order-service -> product-service: UpdateStock (deduct)\n\nThe JWT token is forwarded automatically to upstream services.\nOrder is created with status PENDING.\nThe order_id is automatically saved to collection variables."
					}
				},
				{
					"name": "CreateOrder (multiple items)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.order && res.order.id) {",
									"    pm.collectionVariables.set('order_id_multi', res.order.id);",
									"    console.log('Saved order_id_multi:', res.order.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"quantity\": 1\n    },\n    {\n      \"productId\": \"{{product_id_2}}\",\n      \"quantity\": 3\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/order.v1.OrderService/CreateOrder",
							"host": ["{{order_service_url}}"],
							"path": ["order.v1.OrderService", "CreateOrder"]
						},
						"description": "Place an order with multiple product items.\n\nRequires both product_id and product_id_2 to be set (run both CreateProduct requests first)."
					}
				},
				{
					"name": "GetOrder",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"{{order_id}}\"\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/order.v1.OrderService/GetOrder",
							"host": ["{{order_service_url}}"],
							"path": ["order.v1.OrderService", "GetOrder"]
						},
						"description": "Fetch a single order by ID including all line items."
					}
				},
				{
					"name": "ListOrders (all)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"pageSize\": 20,\n  \"page\": 1\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/order.v1.OrderService/ListOrders",
							"host": ["{{order_service_url}}"],
							"path": ["order.v1.OrderService", "ListOrders"]
						},
						"description": "List all orders with pagination."
					}
				},
				{
					"name": "ListOrders (by user)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"pageSize\": 20,\n  \"page\": 1\n}"
						},
						"url": {
							"raw": "{{order_service_url}}/order.v1.OrderService/ListOrders",
							"host": ["{{order_service_url}}"],
							"path": ["order.v1.OrderService", "ListOrders"]
						},
						"description": "List orders for a specific user."
					}
				},
				{
					"name": "ListOrders (by status)",
					"request": {
						"method": "POST",
